{
    "name": "telegram-md-entities",
    "version": "0.1.0",
    "description": "Lenient markdown → Telegram Bot API { text, entities } renderer built for LLM output: no parse_mode, no escaping, no parse errors; entity-aware message splitting, streaming-friendly partial rendering, offline preview.",
    "keywords": [
        "telegram",
        "telegram-bot",
        "markdown",
        "entities",
        "message-entity",
        "llm",
        "bot-api",
        "grammy",
        "telegraf"
    ],
    "license": "MIT",
    "type": "module",
    "engines": {
        "node": ">=18"
    },
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --target node18 && esbuild src/index.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=dist/browser.js --sourcemap",
        "typecheck": "tsc --noEmit",
        "test": "vitest run --exclude \"test/e2e/**\"",
        "test:e2e": "vitest run test/e2e --no-file-parallelism --testTimeout=120000",
        "test:probe": "RUN_PROBE=1 vitest run test/e2e/entity-limit.probe.e2e.test.ts --no-file-parallelism --testTimeout=120000",
        "test:differential": "RUN_DIFFERENTIAL=1 vitest run test/e2e/differential.e2e.test.ts --no-file-parallelism --testTimeout=600000",
        "check:publish": "publint && attw --pack . --profile esm-only",
        "playground": "pnpm build && npx serve .",
        "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build && pnpm check:publish"
    },
    "dependencies": {
        "mdast-util-from-markdown": "^2.0.3",
        "mdast-util-gfm": "^3.1.0",
        "micromark-extension-gfm": "^3.0.0",
        "ts-pattern": "^5.9.0"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.2",
        "@types/mdast": "^4.0.4",
        "@types/node": "^24.0.0",
        "esbuild": "^0.25.0",
        "fast-check": "^4.9.0",
        "micromark-util-types": "^2.0.2",
        "publint": "^0.3.0",
        "telegramify-markdown": "^1.3.3",
        "tsup": "^8.5.1",
        "typescript": "^5.9.0",
        "vitest": "^4.1.10"
    }
}
